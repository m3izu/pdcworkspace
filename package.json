{
  "name": "snappyworld",
  "version": "1.0.0",
  "description": "SnappyWorld — A Gather.town-style virtual space with proximity video chat",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite client --host\"",
    "server": "node server/index.js",
    "build": "vite build client",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "peer": "^1.0.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "artillery": "^2.0.31",
    "artillery-engine-socketio-v3": "^1.2.0",
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  }
}
